#include <bits/stdc++.h>
using namespace std;

void solve(){
    int n; cin>>n;
    for(int i=2;i<31;++i){
        int k=(1<<i)-1;
        if(n%k==0) {
            cout<<n/k<<endl;
            break;
        }
    }
}

int main() {
   ios::sync_with_stdio(false);
   cin.tie(nullptr);
   int t; cin >> t; while (t--) {
        solve();
    }
return 0;
}
