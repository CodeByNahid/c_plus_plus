#include <bits/stdc++.h>
using namespace std;

void solve(){
    int n; cin>>n;
    map<int,int>mp;
    for(int i=0;i<n;i++){
        int x; cin>>x;
        mp[x]++;
    }
    int m=0,s=0;
    for(auto i:mp){
        s+=i.second;
        m=max(m,i.second);
    }
    cout<<s-m<<endl;
}

int main() {
   ios::sync_with_stdio(false);
   cin.tie(nullptr);
   int t; cin >> t; while (t--) {
        solve();
    }
return 0;
}
